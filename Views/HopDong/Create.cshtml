@model HopDong
@{
    ViewData["Title"] = "Thêm hợp đồng";
}

<div class="max-w-lg">
    <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_2px_10px_-3px_rgba(6,81,237,0.03)] p-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-6">Tạo hợp đồng mới</h2>

        <form id="createForm" class="space-y-5">
            @Html.AntiForgeryToken()
            <div>
                <label asp-for="MaNhanVien" class="block text-xs font-medium text-gray-700 mb-1">Nhân viên</label>
                <select asp-for="MaNhanVien" asp-items="@(ViewData["NhanViens"] as SelectList)" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-gray-400">
                    <option value="">-- Chọn nhân viên --</option>
                </select>
                <span asp-validation-for="MaNhanVien" class="text-xs text-red-500"></span>
            </div>
            <div>
                <label asp-for="LoaiHopDong" class="block text-xs font-medium text-gray-700 mb-1"></label>
                <select asp-for="LoaiHopDong" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-gray-400">
                    <option value="">-- Chọn loại --</option>
                    <option value="Thử việc">Thử việc</option>
                    <option value="Có thời hạn">Có thời hạn</option>
                    <option value="Không thời hạn">Không thời hạn</option>
                </select>
                <span asp-validation-for="LoaiHopDong" class="text-xs text-red-500"></span>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="NgayBatDau" class="block text-xs font-medium text-gray-700 mb-1"></label>
                    <input asp-for="NgayBatDau" type="date" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-gray-400">
                    <span asp-validation-for="NgayBatDau" class="text-xs text-red-500"></span>
                </div>
                <div>
                    <label asp-for="NgayKetThuc" class="block text-xs font-medium text-gray-700 mb-1"></label>
                    <input asp-for="NgayKetThuc" type="date" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-gray-400">
                </div>
            </div>
            <div>
                <label asp-for="Luong" class="block text-xs font-medium text-gray-700 mb-1"></label>
                <input asp-for="Luong" type="number" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-gray-400" placeholder="0">
            </div>
            <div>
                <label asp-for="GhiChu" class="block text-xs font-medium text-gray-700 mb-1"></label>
                <textarea asp-for="GhiChu" rows="3" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-gray-400" placeholder="Ghi chú..."></textarea>
            </div>
            <div class="flex gap-3 pt-2">
                <button type="submit" class="bg-gray-900 text-white hover:bg-gray-800 px-6 py-2.5 rounded-lg text-sm font-medium transition-colors">Lưu hợp đồng</button>
                <a asp-action="Index" class="bg-gray-100 text-gray-700 hover:bg-gray-200 px-6 py-2.5 rounded-lg text-sm font-medium transition-colors">Hủy</a>
            </div>
            <div id="formMessage" class="hidden text-sm px-3 py-2 rounded-lg"></div>
        </form>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('createForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const form = this;
    const msgEl = document.getElementById('formMessage');
    const data = {
        maNhanVien: parseInt(form.querySelector('[name="MaNhanVien"]').value) || 0,
        loaiHopDong: form.querySelector('[name="LoaiHopDong"]').value || null,
        ngayBatDau: form.querySelector('[name="NgayBatDau"]').value || null,
        ngayKetThuc: form.querySelector('[name="NgayKetThuc"]').value || null,
        luong: parseFloat(form.querySelector('[name="Luong"]').value) || 0,
        ghiChu: form.querySelector('[name="GhiChu"]').value || null,
        trangThai: 'Còn hạn'
    };
    try {
        const res = await fetch('/HopDong/CreateApi', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        const result = await res.json();
        if (result.success) {
            msgEl.className = 'text-sm px-3 py-2 rounded-lg bg-emerald-50 text-emerald-700 border border-emerald-100';
            msgEl.textContent = result.message;
            msgEl.classList.remove('hidden');
            setTimeout(() => window.location.href = '/HopDong', 1000);
        } else {
            msgEl.className = 'text-sm px-3 py-2 rounded-lg bg-red-50 text-red-600 border border-red-100';
            msgEl.textContent = result.message;
            msgEl.classList.remove('hidden');
        }
    } catch (err) {
        msgEl.className = 'text-sm px-3 py-2 rounded-lg bg-red-50 text-red-600 border border-red-100';
        msgEl.textContent = 'Có lỗi xảy ra!';
        msgEl.classList.remove('hidden');
    }
});
</script>
}
