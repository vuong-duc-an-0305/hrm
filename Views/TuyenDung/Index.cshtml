@model IEnumerable<TuyenDung>
@{
    ViewData["Title"] = "Quản lý tuyển dụng";
}

<div class="space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <p class="text-sm text-gray-500">Theo dõi vị trí tuyển dụng và trạng thái tiếp nhận hồ sơ</p>
        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
            <a asp-action="Create" class="inline-flex items-center gap-2 bg-gray-900 text-white hover:bg-gray-800 px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
                <iconify-icon icon="solar:add-circle-linear" width="18"></iconify-icon>
                Tạo tin tuyển dụng
            </a>
        }
    </div>

    <form method="get" class="grid grid-cols-1 md:grid-cols-4 gap-3">
        <div class="md:col-span-2 relative">
            <iconify-icon icon="solar:magnifer-linear" class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" width="16"></iconify-icon>
            <input type="text" name="search" value="@ViewData["Search"]" placeholder="Tìm theo vị trí tuyển dụng..." class="w-full bg-white border border-gray-200 rounded-lg pl-9 pr-4 py-2 text-sm focus:outline-none focus:border-gray-400">
        </div>
        <select name="trangThai" class="w-full bg-white border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-gray-400">
            <option value="">-- Tất cả trạng thái --</option>
            <option value="DangTuyen" selected="@(ViewData["TrangThai"]?.ToString() == "DangTuyen")">Đang tuyển</option>
            <option value="DaTuyenDu" selected="@(ViewData["TrangThai"]?.ToString() == "DaTuyenDu")">Đã tuyển đủ</option>
            <option value="DungTuyen" selected="@(ViewData["TrangThai"]?.ToString() == "DungTuyen")">Dừng tuyển</option>
        </select>
        <button type="submit" class="bg-gray-100 hover:bg-gray-200 px-4 py-2 rounded-lg text-sm font-medium transition-colors">Lọc</button>
    </form>

    <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_2px_10px_-3px_rgba(6,81,237,0.03)] overflow-hidden">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-gray-100">
                    <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase">Vị trí</th>
                    <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase hidden md:table-cell">Phòng ban</th>
                    <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase">Số lượng</th>
                    <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase hidden lg:table-cell">Hạn nộp</th>
                    <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase">Trạng thái</th>
                    <th class="text-right px-6 py-3 text-xs font-medium text-gray-500 uppercase">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @foreach (var item in Model)
                {
                    var badgeClass = item.TrangThai == "DaTuyenDu"
                        ? "bg-emerald-50 text-emerald-600"
                        : item.TrangThai == "DungTuyen"
                            ? "bg-red-50 text-red-600"
                            : "bg-sky-50 text-sky-700";

                    <tr class="hover:bg-gray-50/50 transition-colors">
                        <td class="px-6 py-4 font-medium text-gray-900">@item.ViTri</td>
                        <td class="px-6 py-4 text-gray-600 hidden md:table-cell">@item.PhongBan?.TenPhongBan</td>
                        <td class="px-6 py-4 text-gray-700">@item.SoLuongCanTuyen</td>
                        <td class="px-6 py-4 text-gray-500 hidden lg:table-cell">@(item.HanNopHoSo?.ToString("dd/MM/yyyy") ?? "Không giới hạn")</td>
                        <td class="px-6 py-4">
                            <span class="text-xs px-2 py-0.5 rounded-md font-medium @badgeClass">@item.TrangThaiText</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                            {
                                <div class="inline-flex items-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.MaTuyenDung" class="text-gray-400 hover:text-blue-600 transition-colors" title="Sửa">
                                        <iconify-icon icon="solar:pen-linear" width="18"></iconify-icon>
                                    </a>

                                    <form asp-action="UpdateTrangThai" method="post" class="inline-flex items-center gap-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.MaTuyenDung" />
                                        <select name="trangThai" onchange="this.form.submit()" class="text-xs border border-gray-200 rounded-md px-2 py-1">
                                            <option value="DangTuyen" selected="@(item.TrangThai == "DangTuyen")">Đang tuyển</option>
                                            <option value="DaTuyenDu" selected="@(item.TrangThai == "DaTuyenDu")">Đã tuyển đủ</option>
                                            <option value="DungTuyen" selected="@(item.TrangThai == "DungTuyen")">Dừng tuyển</option>
                                        </select>
                                    </form>

                                    <form asp-action="Delete" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa tin tuyển dụng này?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.MaTuyenDung" />
                                        <button type="submit" class="text-gray-400 hover:text-red-600 transition-colors" title="Xóa">
                                            <iconify-icon icon="solar:trash-bin-trash-linear" width="18"></iconify-icon>
                                        </button>
                                    </form>
                                </div>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="text-center py-12 text-gray-400">
                <iconify-icon icon="solar:case-round-linear" width="48" class="mb-2"></iconify-icon>
                <p class="text-sm">Chưa có vị trí tuyển dụng nào</p>
            </div>
        }
    </div>
</div>
