@model TuyenDung
@{
    ViewData["Title"] = "Tạo tin tuyển dụng";
}

<div class="max-w-2xl">
    <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_2px_10px_-3px_rgba(6,81,237,0.03)] p-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-6">Thông tin tuyển dụng</h2>

        <form asp-action="Create" method="post" class="space-y-5">
            @Html.AntiForgeryToken()

            <div>
                <label asp-for="ViTri" class="block text-xs font-medium text-gray-700 mb-1"></label>
                <input asp-for="ViTri" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-gray-400" placeholder="Ví dụ: Backend Developer">
                <span asp-validation-for="ViTri" class="text-xs text-red-500"></span>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label asp-for="MaPhongBan" class="block text-xs font-medium text-gray-700 mb-1"></label>
                    <select asp-for="MaPhongBan" asp-items="@(ViewData["PhongBans"] as SelectList)" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-gray-400">
                        <option value="">-- Chọn phòng ban --</option>
                    </select>
                </div>
                <div>
                    <label asp-for="SoLuongCanTuyen" class="block text-xs font-medium text-gray-700 mb-1"></label>
                    <input asp-for="SoLuongCanTuyen" type="number" min="1" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-gray-400">
                    <span asp-validation-for="SoLuongCanTuyen" class="text-xs text-red-500"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label asp-for="NgayDangTin" class="block text-xs font-medium text-gray-700 mb-1"></label>
                    <input asp-for="NgayDangTin" type="date" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-gray-400">
                    <span asp-validation-for="NgayDangTin" class="text-xs text-red-500"></span>
                </div>
                <div>
                    <label asp-for="HanNopHoSo" class="block text-xs font-medium text-gray-700 mb-1"></label>
                    <input asp-for="HanNopHoSo" type="date" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-gray-400">
                    <span asp-validation-for="HanNopHoSo" class="text-xs text-red-500"></span>
                </div>
            </div>

            <div>
                <label asp-for="MoTa" class="block text-xs font-medium text-gray-700 mb-1"></label>
                <textarea asp-for="MoTa" rows="4" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-gray-400" placeholder="Mô tả ngắn gọn yêu cầu vị trí"></textarea>
                <span asp-validation-for="MoTa" class="text-xs text-red-500"></span>
            </div>

            <input asp-for="TrangThai" type="hidden" value="DangTuyen" />

            <div class="flex gap-3 pt-2">
                <button type="submit" class="bg-gray-900 text-white hover:bg-gray-800 px-6 py-2.5 rounded-lg text-sm font-medium transition-colors">Lưu tin tuyển dụng</button>
                <a asp-action="Index" class="bg-gray-100 text-gray-700 hover:bg-gray-200 px-6 py-2.5 rounded-lg text-sm font-medium transition-colors">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
